# Configuration for the Hermes-style Development Agent
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Required ---
# Your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Optional ---
# Override the default LLM model (must be available on OpenRouter)
# Free options:  google/gemma-4-31b-it:free  |  deepseek/deepseek-r1:free
# Paid options:  deepseek/deepseek-chat-v3-5  |  openai/gpt-4o-mini
MODEL_NAME=google/gemma-4-31b-it:free

# Future: add Telegram bot token here for remote interaction
# TELEGRAM_TOKEN=your_telegram_bot_token_here
